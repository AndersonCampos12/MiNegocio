generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  SUPERADMIN
  ADMINISTRADOR
  VENDEDOR
  CAJERO
  CLIENTE
}

enum EstadoNegocio {
  PENDIENTE
  ACTIVO
  BLOQUEADO
}

model Negocio {
  id        String        @id @default(uuid())
  nombre    String
  slug      String        @unique
  plan      String        @default("MULTI")
  estado    EstadoNegocio @default(PENDIENTE)
  creadoEn  DateTime      @default(now()) @map("creado_en")
  socios    Socio[]
  productos Producto[]    // ← Productos pertenecen al Negocio
  ventas    Venta[]       // ← Ventas pertenecen al Negocio
  @@map("negocios")
}

model Socio {
  id        String    @id @default(uuid())
  negocioId String?
  negocio   Negocio?  @relation(fields: [negocioId], references: [id])
  nombre    String
  cedula     String?   @unique // <- Añadir para el RUC/Cédula
  email     String    @unique
  password  String
  rol       Rol       @default(CLIENTE)
  ventasRealizadas Venta[] @relation("VendedorFactura")
  compras          Venta[] @relation("ClienteFactura")
  @@map("socios")
}

model Producto {
  id          String         @id @default(uuid())
  negocioId   String         @map("negocio_id")  // ← CAMBIADO
  negocio     Negocio        @relation(fields: [negocioId], references: [id])
  nombre      String
  valor       Decimal
  stock       Int            @default(0)
  imagenUrl   String?        @map("imagen_url")
  descripcion String?
  qrCode      String?        @map("qr_code")
  activo      Boolean        @default(true)
  creadoEn    DateTime       @default(now()) @map("creado_en")
  detalles    DetalleVenta[]
  alertas     Alerta[]
  @@map("productos")
}

model Venta {
  id         String         @id @default(uuid())
  negocioId  String         @map("negocio_id")
  negocio    Negocio        @relation(fields: [negocioId], references: [id])
  
  // VENDEDOR / CAJERO
  socioId    String         @map("socio_id")
  socio      Socio          @relation("VendedorFactura", fields: [socioId], references: [id])
  
  // CLIENTE
  clienteId  String?        @map("cliente_id")
  cliente    Socio?         @relation("ClienteFactura", fields: [clienteId], references: [id])

  subtotal   Decimal        @default(0)
  impuestos  Decimal        @default(0)
  total      Decimal
  
  creadoEn   DateTime       @default(now()) @map("creado_en")
  detalles   DetalleVenta[]

  @@map("ventas")
}

model DetalleVenta {
  id         String   @id @default(uuid())
  ventaId    String   @map("venta_id")
  productoId String   @map("producto_id")
  cantidad   Int
  precioUnit Decimal  @map("precio_unit")
  venta      Venta    @relation(fields: [ventaId], references: [id])
  producto   Producto @relation(fields: [productoId], references: [id])
  @@map("detalle_ventas")
}

model Alerta {
  id         String   @id @default(uuid())
  productoId String   @map("producto_id")
  mensaje    String
  creadoEn   DateTime @default(now()) @map("creado_en")
  producto   Producto @relation(fields: [productoId], references: [id])
  @@map("alertas")
}

model SesionCaja {
  id        String   @id @default(uuid())
  creadoEn  DateTime @default(now()) @map("creado_en")
  @@map("sesiones_caja")
}